{
  "openapi": "3.0.0",
  "info": {
    "title": "E-commerce API - CSE341",
    "description": "Bilingual API Documentation for product and category management with Google OAuth2 Authentication.",
    "version": "1.0.0",
    "contact": {
      "name": "Kevin Guzman",
      "email": "kguzman077@gmail.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server (Local)"
    },
    {
      "url": "https://ecommer-api341.onrender.com",
      "description": "Production Server (Render)"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie. Login at /auth/google first."
      }
    },
    "schemas": {
      "Category": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Electronics", "minLength": 2, "maxLength": 50 },
          "description": { "type": "string", "example": "Gadgets and devices" },
          "slug": { "type": "string", "example": "electronics" },
          "parentCategory": { "type": "string", "example": "65f1a2b3c4d5e6f7a8b9c0d1" },
          "isActive": { "type": "boolean", "default": true },
          "displayOrder": { "type": "integer", "example": 0 }
        }
      },
      "Product": {
        "type": "object",
        "required": ["name", "sku", "description", "price", "category", "brand", "condition", "weight"],
        "properties": {
          "name": { "type": "string", "example": "Wireless Headphones", "minLength": 3 },
          "sku": { "type": "string", "example": "WH-2025-BLK" },
          "description": { "type": "string", "example": "Noise-cancelling headphones", "minLength": 10 },
          "price": { "type": "number", "example": 89.99, "minimum": 0 },
          "category": { "type": "string", "example": "65f1a2b3c4d5e6f7a8b9c0d1" },
          "stock": { "type": "integer", "example": 50, "minimum": 0 },
          "brand": { "type": "string", "example": "AudioMax" },
          "condition": { "type": "string", "enum": ["new", "refurbished", "used"], "example": "new" },
          "weight": { "type": "number", "example": 0.5 },
          "isActive": { "type": "boolean", "default": true }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Detailed error message here" }
        }
      }
    }
  },
  "paths": {
    "/auth/google": {
      "get": {
        "summary": "Login with Google",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Redirects to Google OAuth" } }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Session closed" } }
      }
    },
    "/products": {
      "get": {
        "summary": "Get all products",
        "tags": ["Products"],
        "responses": { "200": { "description": "Returns array of products" } }
      },
      "post": {
        "summary": "Create product (Auth Required)",
        "tags": ["Products"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Validation Error (Missing fields/Invalid data)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Conflict (Duplicate SKU)" }
        }
      }
    },
    "/products/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
      "get": {
        "summary": "Get product by ID",
        "tags": ["Products"],
        "responses": {
          "200": { "description": "Success" },
          "400": { "description": "Invalid ID format" },
          "404": { "description": "Product not found" }
        }
      },
      "put": {
        "summary": "Update product (Auth Required)",
        "tags": ["Products"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "Invalid ID or Validation Error" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "summary": "Delete product (Auth Required)",
        "tags": ["Products"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Deleted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Get all categories",
        "tags": ["Categories"],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "summary": "Create category (Auth Required)",
        "tags": ["Categories"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Validation Error" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Conflict (Name/Slug exists)" }
        }
      }
    },
    "/categories/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
      "get": {
        "summary": "Get category by ID",
        "tags": ["Categories"],
        "responses": {
          "200": { "description": "Success" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "summary": "Update category (Auth Required)",
        "tags": ["Categories"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "Self-parenting error or Invalid ID" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "summary": "Delete category (Auth Required)",
        "tags": ["Categories"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Category in use by products" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    }
  }
}