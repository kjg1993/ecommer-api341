{
  "openapi": "3.0.0",
  "info": {
    "title": "E-commerce API - CSE341",
    "description": "Full API documentation with Google OAuth2. Access restricted routes by logging in first at /auth/google.",
    "version": "1.0.0",
    "contact": {
      "name": "Kevin Guzman",
      "email": "kguzman077@gmail.com"
    }
  },
  "servers": [
    {
      "url": "https://ecommer-api341.onrender.com",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local Server"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie. Authenticate via /auth/google."
      }
    },
    "schemas": {
      "Category": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Electronics" },
          "description": { "type": "string", "example": "Gadgets" },
          "slug": { "type": "string", "example": "electronics" },
          "isActive": { "type": "boolean", "default": true }
        }
      },
      "Product": {
        "type": "object",
        "required": ["name", "sku", "price", "category"],
        "properties": {
          "name": { "type": "string", "example": "Wireless Headphones" },
          "sku": { "type": "string", "example": "WH-100-PRO" },
          "price": { "type": "number", "example": 99.99 },
          "category": {
            "type": "string",
            "example": "65f1a2b3c4d5e6f7a8b9c0d1"
          },
          "brand": { "type": "string", "example": "AudioMax" },
          "condition": {
            "type": "string",
            "enum": ["new", "used", "refurbished"]
          },
          "weight": { "type": "number", "example": 0.5 }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": {
            "type": "string",
            "example": "Detailed error message here"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/google": {
      "get": {
        "summary": "Login with Google",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Redirecting to Google..." } }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Logged out successfully" } }
      }
    },
    "/products": {
      "get": {
        "summary": "Get all products",
        "tags": ["Products"],
        "responses": {
          "200": { "description": "List of products retrieved" }
        }
      },
      "post": {
        "summary": "Create product",
        "tags": ["Products"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Product" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": {
            "description": "Bad Request (Validation Error)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Conflict (Duplicate SKU)" }
        }
      }
    },
    "/products/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "summary": "Get product by ID",
        "tags": ["Products"],
        "responses": {
          "200": { "description": "Success" },
          "400": { "description": "Invalid ID format" },
          "404": {
            "description": "Product Not Found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update product",
        "tags": ["Products"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Product" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "Bad Request (Validation Error)" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Product Not Found" }
        }
      },
      "delete": {
        "summary": "Delete product",
        "tags": ["Products"],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Invalid ID" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Product Not Found" }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Get all categories",
        "tags": ["Categories"],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "summary": "Create category",
        "tags": ["Categories"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Category" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request (Missing Fields)" },
          "401": { "description": "Unauthorized" },
          "409": { "description": "Conflict (Duplicate Name)" }
        }
      }
    },
    "/categories/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "summary": "Get category by ID",
        "tags": ["Categories"],
        "responses": {
          "200": { "description": "Success" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Category Not Found" }
        }
      },
      "put": {
        "summary": "Update category",
        "tags": ["Categories"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Category" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category Not Found" }
        }
      },
      "delete": {
        "summary": "Delete category",
        "tags": ["Categories"],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Bad Request (Category in use)" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category Not Found" }
        }
      }
    }
  }
}
